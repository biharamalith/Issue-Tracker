# Firebase Configuration
# Copy this file to .env and fill in your Firebase project credentials
# Get these values from Firebase Console > Project Settings > Your apps > Web app

FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_APP_ID=your_app_id

# Note: For this implementation, we're using direct config in firebase.ts
# To use environment variables, install react-native-dotenv and update firebase.ts
